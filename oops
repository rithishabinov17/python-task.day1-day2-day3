#example

class Animal:
    def sound(self):
        print("Animals make sound")
class Dog(Animal):
    def bark(self):
        print("Dog barks")
d=Dog()
d.sound()
d.bark()

#multiple level inheritance

class fr_ob1:
    def first_elite(self):
        print("first elite")
    def second_elite(self):
        print("second elite")
class fr_ob2(fr_ob1):
    def third_elite(self):
        print("third elite")
    def fourth_elite(self):
        print("fourth elite")
class fr_ob3(fr_ob2):
    def fifth_elite(self):
        print("fifth elite")
    def sixth_elite(self):
        print("sixth elite")
d= fr_ob3()
d.sixth_elite()
d.fifth_elite()
d.fourth_elite()
d.third_elite()
d.second_elite()
d.first_elite()

        
        
        
