#parmeter coding-one user name in used  two function  
class Details:
    def setdata(self):
        # self → current object
        # username → object variable
        self.username = input("Enter username: ")

    def res(self, age):
        print(self.username)
        print(age)

    def login(self):
        print(self.username)

g = Details()
g.setdata()
g.res(22)
g.login()


